# Caddy config для прода. На сервере замени yulik3d.ru на свой домен.
# Caddy сам получит Let's Encrypt сертификат при первом старте и обновит автоматически.

yulik3d.ru, www.yulik3d.ru {
    encode zstd gzip

    reverse_proxy frontend:80

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Frame-Options "SAMEORIGIN"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }

    log {
        output file /data/access.log {
            roll_size 10mb
            roll_keep 5
        }
        format json
    }
}
