# =========================================================================
# yulik3d — environment variables template
# Скопируй в .env и заполни реальными значениями.
# .env в .gitignore — никогда не коммитить.
# =========================================================================

# -------- Backend ---------------------------------------------------------
# BACKEND_PORT — порт ВНУТРИ контейнера. Должен быть 8080 (на него проксирует nginx фронта).
BACKEND_PORT=
BACKEND_HOST=
# BACKEND_EXTERNAL_PORT — порт НАРУЖУ (через который Swagger и прямые curl).
# Если 8080 занят — поменяй на любой свободный.
BACKEND_EXTERNAL_PORT=
# "development" | "production"
APP_ENV=
# "debug" | "info" | "warn" | "error"
LOG_LEVEL=
# CORS — список origin через запятую (без пробелов)
CORS_ALLOWED_ORIGINS=

# Публичный базовый URL бэка (для ссылок в Swagger и т.п.)
PUBLIC_BACKEND_URL=
# Публичный URL фронта — для генерации ссылок в письмах (ресет пароля, заказы).
# В dev: http://localhost:5173. В prod: https://yulik3d.ru
PUBLIC_FRONTEND_URL=

# -------- PostgreSQL ------------------------------------------------------
POSTGRES_HOST=
POSTGRES_PORT=
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_SSLMODE=

# -------- Redis -----------------------------------------------------------
REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=
REDIS_DB=
# Отдельная DB для очереди писем (изолированно от сессий на DB 0). Рекомендуется 1.
REDIS_ASYNQ_DB=

# -------- Session / Auth --------------------------------------------------
# Секунды. 2592000 = 30 дней
SESSION_TTL_SECONDS=
# В dev можно false, в prod — всегда true
COOKIE_SECURE=
# Имя cookie
COOKIE_NAME=
# Домен cookie (пусто = host-only, рекомендуется в dev)
COOKIE_DOMAIN=

# Rate-limit на /auth/login и /auth/register
RATE_LIMIT_AUTH_ATTEMPTS=
RATE_LIMIT_AUTH_WINDOW_SECONDS=

# Argon2id parameters (production defaults)
ARGON2_MEMORY_KIB=
ARGON2_ITERATIONS=
ARGON2_PARALLELISM=

# -------- MinIO -----------------------------------------------------------
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
MINIO_HOST=
MINIO_PORT=
MINIO_CONSOLE_PORT=
MINIO_BUCKET=
# Публичный URL для сборки ссылок на картинки (бэк отдаёт в API)
MINIO_PUBLIC_URL=
MINIO_USE_SSL=

# -------- Uploads ---------------------------------------------------------
# Максимальный размер картинки в байтах (10 MB)
MAX_UPLOAD_BYTES=

# -------- Email / SMTP ----------------------------------------------------
# VK WorkSpace / Mail.ru. Порт 465 = implicit TLS (рекомендуется).
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
# Пароль ящика. Без него письма не отправляются (только лог "smtp not configured").
SMTP_PASS=
SMTP_FROM_NAME=
SMTP_FROM_EMAIL=
# true для порта 465, false для 587 (STARTTLS)
SMTP_USE_SSL=

# Куда слать админ-уведомления о новых заказах (реальный почтовый ящик админа)
ADMIN_NOTIFY_EMAIL=
# Email для футера писем («По вопросам пишите: ...»). Может быть пустым.
MAIL_SUPPORT_CONTACT=

# -------- Восстановление пароля ------------------------------------------
# TTL токена в секундах (3600 = 1 час)
PWRESET_TOKEN_TTL_SECONDS=
# Минимальный интервал между запросами для одного email в секундах (60 = 1 минута)
PWRESET_THROTTLE_SECONDS=
