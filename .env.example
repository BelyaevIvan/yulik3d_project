# =========================================================================
# yulik3d — environment variables template
# Скопируй в .env и заполни реальными значениями.
# .env в .gitignore — никогда не коммитить.
# =========================================================================

# -------- Backend ---------------------------------------------------------
# BACKEND_PORT — порт ВНУТРИ контейнера. Должен быть 8080 (на него проксирует nginx фронта).
BACKEND_PORT=8080
BACKEND_HOST=0.0.0.0
# BACKEND_EXTERNAL_PORT — порт НАРУЖУ (через который Swagger и прямые curl).
# Если 8080 занят — поменяй на любой свободный.
BACKEND_EXTERNAL_PORT=8080
# "development" | "production"
APP_ENV=development
# "debug" | "info" | "warn" | "error"
LOG_LEVEL=info
# CORS — список origin через запятую (без пробелов)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Публичный базовый URL бэка (для ссылок в Swagger, письмах и т.п.)
PUBLIC_BACKEND_URL=http://localhost:8090

# -------- PostgreSQL ------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=yulik3d
POSTGRES_USER=yulik3d
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_SSLMODE=disable

# -------- Redis -----------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me-redis-password
REDIS_DB=0

# -------- Session / Auth --------------------------------------------------
# Секунды. 2592000 = 30 дней
SESSION_TTL_SECONDS=2592000
# В dev можно false, в prod — всегда true
COOKIE_SECURE=false
# Имя cookie
COOKIE_NAME=session
# Домен cookie (пусто = host-only, рекомендуется в dev)
COOKIE_DOMAIN=

# Rate-limit на /auth/login и /auth/register
RATE_LIMIT_AUTH_ATTEMPTS=5
RATE_LIMIT_AUTH_WINDOW_SECONDS=900

# Argon2id parameters (production defaults)
ARGON2_MEMORY_KIB=65536
ARGON2_ITERATIONS=3
ARGON2_PARALLELISM=2

# -------- MinIO -----------------------------------------------------------
MINIO_ROOT_USER=minio-admin
MINIO_ROOT_PASSWORD=change-me-minio-password
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=yulik3d
# Публичный URL для сборки ссылок на картинки (бэк отдаёт в API)
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_USE_SSL=false

# -------- Uploads ---------------------------------------------------------
# Максимальный размер картинки в байтах (10 MB)
MAX_UPLOAD_BYTES=10485760
